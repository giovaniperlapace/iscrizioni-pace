SUPABASE_URL=https://iscrizioni-supabase.stefano-orlando.it
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Consigliato: segreto server-side stabile per cifrare i token QR recuperabili.
QR_TOKEN_ENCRYPTION_SECRET=

NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
PUBLIC_SITE_URL=http://localhost:3000

EMAIL_FROM=registrationspeace@santegidio.org
EMAIL_USER=registrationspeace@santegidio.org
EMAIL_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
# Usa "log" in sviluppo per stampare le email in console senza inviarle.
EMAIL_DELIVERY_MODE=smtp

# Alias supportato in locale per Gmail Workspace.
GMAIL_APP_PASSWORD=

